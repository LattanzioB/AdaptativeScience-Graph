# =====================================================================
# Lucia Gomez -> 10 pts (arboles-005 abandonada: solo geolocalizacion)
# Sin "completar-protocolo" (no alcanzo paso terminal) ni "subir-foto".
# =====================================================================
<award/arboles-005-geo> a pbl:PointAward ;
  pbl:awardedTo <estado/lucia-gomez-relevamiento> ;
  pbl:fromActivity <actividad/geolocalizar> ; pbl:appliedRule <regla/geo> ;
  pbl:fromContribution <muestra/arboles-005> ; pbl:points 10 ;
  pbl:awardedAt "2026-06-10T10:00:00-03:00"^^xsd:dateTime .
