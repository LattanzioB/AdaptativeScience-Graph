cipa:ProyectoPiloto rdfs:subClassOf cipa:Proyecto .

cipa:area-botanica
  a cipa:AreaConocimiento .

<https://w3id.org/cipa/data/proyecto/arboles-nativos>
  a cipa:ProyectoPiloto ;
  cipa:tieneNombre "Arboles nativos" ;
  cipa:tieneDescripcion "Proyecto piloto para relevar arboles nativos en espacios publicos." ;
  cipa:perteneceA cipa:area-botanica ;
  cipa:tieneProtocoloActivo <https://w3id.org/cipa/data/protocolo/relevamiento-arboles> ;
  cipa:tieneProtocolo <https://w3id.org/cipa/data/protocolo/relevamiento-arboles> ;
  rdfs:label "Arboles nativos"@es .

<https://w3id.org/cipa/data/protocolo/relevamiento-arboles>
  a cipa:Protocolo ;
  cipa:tieneNombre "Relevamiento de arboles" ;
  cipa:tieneDescripcion "Flujo minimo para registrar foto, especie y observaciones." ;
  cipa:tieneEstado cipa:estado-activo ;
  cipa:tienePrimerPaso <https://w3id.org/cipa/data/paso/registrar-foto> ;
  cipa:tienePaso
    <https://w3id.org/cipa/data/paso/registrar-foto>,
    <https://w3id.org/cipa/data/paso/identificar-especie>,
    <https://w3id.org/cipa/data/paso/observaciones> .

<https://w3id.org/cipa/data/paso/registrar-foto>
  a cipa:Paso, cipa:PasoMultimedia ;
  cipa:tieneEnunciado <https://w3id.org/cipa/data/enunciado/registrar-foto> ;
  cipa:siguientePaso <https://w3id.org/cipa/data/paso/identificar-especie> .

<https://w3id.org/cipa/data/enunciado/registrar-foto>
  a cipa:EnunciadoMultimedia ;
  cipa:tieneDescripcion "Subi una foto clara del arbol relevado." .

<https://w3id.org/cipa/data/paso/identificar-especie>
  a cipa:Paso, cipa:PasoCuestionario ;
  cipa:tieneEnunciado <https://w3id.org/cipa/data/enunciado/identificar-especie> ;
  cipa:siguientePaso <https://w3id.org/cipa/data/paso/observaciones> .

<https://w3id.org/cipa/data/enunciado/identificar-especie>
  a cipa:EnunciadoCuestionario ;
  cipa:tieneDescripcion "Selecciona la especie observada." ;
  cipa:tieneTipoRespuesta cipa:respuesta-selector-unico ;
  cipa:tieneOpcionRespuesta <https://w3id.org/cipa/data/opcion/ceibo> .

<https://w3id.org/cipa/data/opcion/ceibo>
  a cipa:OpcionRespuestaCuestionario ;
  rdfs:label "Ceibo"@es .

<https://w3id.org/cipa/data/paso/observaciones>
  a cipa:Paso, cipa:PasoCuestionario ;
  cipa:tieneEnunciado <https://w3id.org/cipa/data/enunciado/observaciones> .

<https://w3id.org/cipa/data/enunciado/observaciones>
  a cipa:EnunciadoCuestionario ;
  cipa:tieneDescripcion "Agrega observaciones adicionales." ;
  cipa:tieneTipoRespuesta cipa:respuesta-texto-libre .

<https://w3id.org/cipa/data/transicion/foto-a-especie>
  a cipa:Transicion ;
  cipa:desdePaso <https://w3id.org/cipa/data/paso/registrar-foto> ;
  cipa:haciaPaso <https://w3id.org/cipa/data/paso/identificar-especie> .

<https://w3id.org/cipa/data/transicion/especie-a-observaciones>
