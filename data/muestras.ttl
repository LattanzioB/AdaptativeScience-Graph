# Muestras geolocalizadas (H2.4)
# Cobertura:
#  - Ambas ramas del protocolo de arboles (nativa: 001/002/004; no nativa: 003).
#  - Multiplicidad simultanea: Ana aporta en arboles y en aves.
#  - Historial longitudinal: Ana tiene muestras en marzo, abril y junio.
#  - Provincias distintas (Buenos Aires, Cordoba, Mendoza, Santa Fe) via rdfs:label.
#  - Tipos de valor: valorTexto, seleccionaOpcion y valorMultimedia.
@base <https://w3id.org/cipa/data/> .
@prefix cipa: <https://w3id.org/cipa/ontology#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =====================================================================
# Ubicaciones (provincia en rdfs:label; lat/long en decimales)
# =====================================================================
<ubicacion/arboles-001>
  a cipa:Ubicacion ; rdfs:label "Buenos Aires"@es ;
  cipa:latitud "-34.6037"^^xsd:decimal ; cipa:longitud "-58.3816"^^xsd:decimal .
<ubicacion/arboles-002>
  a cipa:Ubicacion ; rdfs:label "Cordoba"@es ;
  cipa:latitud "-31.4201"^^xsd:decimal ; cipa:longitud "-64.1888"^^xsd:decimal .
<ubicacion/arboles-003>
  a cipa:Ubicacion ; rdfs:label "Mendoza"@es ;
  cipa:latitud "-32.8895"^^xsd:decimal ; cipa:longitud "-68.8458"^^xsd:decimal .
<ubicacion/arboles-004>
  a cipa:Ubicacion ; rdfs:label "Buenos Aires"@es ;
  cipa:latitud "-34.6158"^^xsd:decimal ; cipa:longitud "-58.4333"^^xsd:decimal .
<ubicacion/aves-001>
  a cipa:Ubicacion ; rdfs:label "Santa Fe"@es ;
  cipa:latitud "-31.6333"^^xsd:decimal ; cipa:longitud "-60.7000"^^xsd:decimal .
<ubicacion/aves-002>
  a cipa:Ubicacion ; rdfs:label "Mendoza"@es ;
  cipa:latitud "-32.9468"^^xsd:decimal ; cipa:longitud "-68.8500"^^xsd:decimal .

# =====================================================================
# Adjuntos multimedia (foto subida por el participante)
# =====================================================================
<adjunto/foto-ceibo-001>
  a cipa:AdjuntoMultimedia ;
  cipa:urlAdjunto "https://w3id.org/cipa/data/media/foto-ceibo-001.jpg"^^xsd:anyURI ;
  cipa:tipoMime "image/jpeg" .
<adjunto/foto-algarrobo-002>
  a cipa:AdjuntoMultimedia ;
  cipa:urlAdjunto "https://w3id.org/cipa/data/media/foto-algarrobo-002.jpg"^^xsd:anyURI ;
  cipa:tipoMime "image/jpeg" .
<adjunto/foto-jacaranda-004>
  a cipa:AdjuntoMultimedia ;
  cipa:urlAdjunto "https://w3id.org/cipa/data/media/foto-jacaranda-004.jpg"^^xsd:anyURI ;
  cipa:tipoMime "image/jpeg" .
<adjunto/foto-hornero-001>
  a cipa:AdjuntoMultimedia ;
  cipa:urlAdjunto "https://w3id.org/cipa/data/media/foto-hornero-001.jpg"^^xsd:anyURI ;
  cipa:tipoMime "image/jpeg" .
<adjunto/foto-chimango-002>
  a cipa:AdjuntoMultimedia ;
  cipa:urlAdjunto "https://w3id.org/cipa/data/media/foto-chimango-002.jpg"^^xsd:anyURI ;
  cipa:tipoMime "image/jpeg" .

# =====================================================================
# Muestra arboles-001 - Ana / Buenos Aires / 2026-03-10 - rama NATIVA (Ceibo)
# =====================================================================
<muestra/arboles-001>
  a cipa:Muestra ;
  cipa:ejecutaProtocolo <protocolo/arboles-nativos> ;
  cipa:respondidaPor <persona/ana-perez> ;
  cipa:registradaEn <ubicacion/arboles-001> ;
  cipa:fechaHora "2026-03-10T09:15:00-03:00"^^xsd:dateTime ;
  cipa:tieneRespuesta
    <respuesta/arboles-001-es-nativa>,
    <respuesta/arboles-001-nombre>,
    <respuesta/arboles-001-caracteristicas>,
    <respuesta/arboles-001-foto> .

<respuesta/arboles-001-es-nativa>
  a cipa:MuestraRespuesta ;
  cipa:correspondeAPaso <paso/es-nativa> ;
  cipa:seleccionaOpcion <opcion/es-nativa-si> ;
  cipa:fechaHoraRespuesta "2026-03-10T09:15:30-03:00"^^xsd:dateTime .
<respuesta/arboles-001-nombre>
  a cipa:MuestraRespuesta ;
  cipa:correspondeAPaso <paso/nombre-especie> ;
  cipa:valorTexto "Ceibo" ;
  cipa:fechaHoraRespuesta "2026-03-10T09:16:00-03:00"^^xsd:dateTime .
<respuesta/arboles-001-caracteristicas>
  a cipa:MuestraRespuesta ;
  cipa:correspondeAPaso <paso/caracteristicas> ;
  cipa:seleccionaOpcion <opcion/flores>, <opcion/frutos> ;
  cipa:fechaHoraRespuesta "2026-03-10T09:16:45-03:00"^^xsd:dateTime .
<respuesta/arboles-001-foto>
  a cipa:MuestraRespuesta ;
  cipa:correspondeAPaso <paso/foto-arbol> ;
  cipa:valorMultimedia <adjunto/foto-ceibo-001> ;
  cipa:fechaHoraRespuesta "2026-03-10T09:17:20-03:00"^^xsd:dateTime .

