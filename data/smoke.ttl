  cipa:disparadaPor <https://w3id.org/cipa/data/opcion/ceibo> .

<https://w3id.org/cipa/data/persona/ada>
  a cipa:Persona ;
  cipa:personaId "ada" ;
  cipa:nivelExpertise cipa:expertise-intermedio ;
  foaf:name "Ada Lovelace" .

